---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Cases | SportSEO Specialist" pageCss="/assets/css/cases.css" current="cases">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="hero__bg">
      <div class="hero__circle hero__circle--1"></div>
      <div class="hero__circle hero__circle--2"></div>
      <div class="hero__grid"></div>
    </div>
    <div class="container page-hero__inner">
      <span class="section__label">Portfolio</span>
      <h1>Projecten die <span class="gradient-text">resultaat</span> leveren</h1>
      <p>Van AI-dashboards tot automatiseringen, concrete projecten voor echte bedrijven, met meetbare uitkomsten.</p>
    </div>
  </section>

  <!-- FEATURED CASE: SPORTPOEDER -->
  <section class="section case-featured" id="sportpoeder">
    <div class="container">

      <div class="cf__header fade-in">
        <div class="cf__meta">
          <span class="cf__client">Sportpoeder.nl</span>
          <span class="cf__badge cf__badge--orange">SEO</span>
          <span class="cf__badge">Content</span>
          <span class="cf__badge">Conversie-optimalisatie</span>
        </div>
        <h2 class="cf__title">
          Van 3,4 naar 8,7 miljoen vertoningen<br />
          <span class="gradient-text">in slechts 6 maanden</span>
        </h2>
        <p class="cf__lead">
          Sportpoeder.nl is een van de grootste aanbieders van sportvoeding kortingscodes in Nederland.
          Door een complete SEO-aanpak — van geoptimaliseerde kortingscode-pagina's tot gerichte SEO-blogs —
          verdubbelden het bereik en de klikken in een half jaar tijd.
        </p>
      </div>

      <div class="cf__detail">

        <div class="cf__content fade-in">

          <div class="cf__block">
            <div class="cf__block-label">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="10" cy="10" r="8"/><path d="M10 6v4l3 3"/></svg>
              De uitdaging
            </div>
            <p>
              Sportpoeder stond al sterk op kortingscodes, maar liet enorm veel organisch verkeer liggen.
              De pagina's waren niet optimaal ingericht voor Google en er was nauwelijks ondersteunende content
              die bezoekers eerder in hun zoekproces kon aantrekken.
            </p>
          </div>

          <div class="cf__block">
            <div class="cf__block-label cf__block-label--blue">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="14" cy="4" r="2"/><circle cx="6" cy="10" r="2"/><circle cx="14" cy="16" r="2"/><path d="M7.8 9l4.4-4M7.8 11l4.4 4"/></svg>
              De oplossing
            </div>
            <p>
              Volledige SEO-strategie: optimalisatie van alle kortingscode-pagina's, gerichte SEO-blogs voor
              long-tail zoekwoorden en technische verbeteringen. Resultaat: structureel meer zichtbaarheid
              en klikken vanuit Google.
            </p>
          </div>

          <div class="cf__tech">
            <span class="cf__tech-label">Wat er is gedaan</span>
            <div class="cf__tech-list">
              <span class="tool-badge tool-badge--orange">On-page SEO</span>
              <span class="tool-badge tool-badge--orange">SEO-blogs</span>
              <span class="tool-badge">Kortingscode-pagina's</span>
              <span class="tool-badge">Zoekwoordenonderzoek</span>
              <span class="tool-badge">Technische SEO</span>
              <span class="tool-badge tool-badge--orange">Google Search Console</span>
            </div>
          </div>

          <div class="cf__systems">
            <span class="cf__tech-label">Bekijk het resultaat</span>
            <div class="cf__sys-list">
              <a href="https://sportpoeder.nl/" target="_blank" rel="noopener" class="btn btn--primary" style="margin-top:.5rem">Sportpoeder.nl →</a>
            </div>
          </div>

        </div>

        <div class="cf__visual fade-in fade-in-delay-1">
          <div class="dashboard-mock">
            <div class="dm__chrome">
              <div class="dm__dots">
                <span class="dm__dot" style="background:#ff5f57"></span>
                <span class="dm__dot" style="background:#febc2e"></span>
                <span class="dm__dot" style="background:#28c840"></span>
              </div>
              <span class="dm__title">sportpoeder.nl</span>
              <div class="dm__chrome-right">
                <span class="dm__ai-pill">
                  <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="5" r="3"/><path d="M2 11c0-2.2 1.8-4 4-4s4 1.8 4 4"/></svg>
                  Live
                </span>
              </div>
            </div>
            <div class="dm__body" style="padding:0">
              <img
                src="/assets/images/afbeelding-case-sportpoeder.png"
                alt="Sportpoeder case"
                style="width:100%;display:block;border-radius:0 0 10px 10px;object-fit:cover"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="cf__results fade-in">
        <div class="cf__result-card cf__result-card--orange">
          <strong>8,7M</strong>
          <span>vertoningen in 6 maanden (was 3,4M)</span>
        </div>
        <div class="cf__result-card">
          <strong>135K</strong>
          <span>klikken in 6 maanden (was 60K)</span>
        </div>
        <div class="cf__result-card cf__result-card--orange">
          <strong>+156%</strong>
          <span>meer vertoningen in een half jaar</span>
        </div>
        <div class="cf__result-card">
          <strong>+125%</strong>
          <span>meer organische klikken vanuit Google</span>
        </div>
      </div>

    </div>
  </section>

  <!-- FEATURED CASE: VOETBAL FUN NOORD -->
  <section class="section case-featured" id="voetbalfunnoord">
    <div class="container">

      <div class="cf__header fade-in">
        <div class="cf__meta">
          <span class="cf__client">Voetbal Fun Noord</span>
          <span class="cf__badge cf__badge--orange">Website</span>
          <span class="cf__badge">SEO-strategie</span>
        </div>
        <h2 class="cf__title">
          Een nieuwe online basis voor de organisatie,<br />
          <span class="gradient-text">beter vindbaar in de regio</span>
        </h2>
        <p class="cf__lead">
          Voetbal Fun Noord was nauwelijks vindbaar online. Ze organiseren leuke voetbaldagen
          voor voetbalclubs, zoals seizoensafsluitingen en -openingen. We bouwden een nieuwe
          website en zetten een complete SEO-strategie op zodat ze structureel
          gevonden worden door clubs in de regio.
        </p>
      </div>

      <div class="cf__detail">

        <div class="cf__content fade-in">

          <div class="cf__block">
            <div class="cf__block-label">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="10" cy="10" r="8"/><path d="M10 6v4l3 3"/></svg>
              De uitdaging
            </div>
            <p>
              De oude website was verouderd, niet mobielvriendelijk en stond nergens
              in Google. Voetbalclubs die op zoek waren naar een leuke voetbaldag vonden de organisatie simpelweg niet terug.
            </p>
          </div>

          <div class="cf__block">
            <div class="cf__block-label cf__block-label--blue">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="14" cy="4" r="2"/><circle cx="6" cy="10" r="2"/><circle cx="14" cy="16" r="2"/><path d="M7.8 9l4.4-4M7.8 11l4.4 4"/></svg>
              De oplossing
            </div>
            <p>
              Nieuwe mobielvriendelijke website plus een complete SEO-strategie:
              zoekwoordenonderzoek, technische optimalisatie en lokale SEO zodat
              Voetbal Fun Noord gevonden wordt door iedereen die in de buurt zoekt.
            </p>
          </div>

          <div class="cf__tech">
            <span class="cf__tech-label">Wat er is gedaan</span>
            <div class="cf__tech-list">
              <span class="tool-badge tool-badge--orange">Website design</span>
              <span class="tool-badge tool-badge--orange">Lokale SEO</span>
              <span class="tool-badge">Zoekwoordenonderzoek</span>
              <span class="tool-badge">Technische optimalisatie</span>
              <span class="tool-badge">Mobiel vriendelijk</span>
              <span class="tool-badge tool-badge--orange">Google Search Console</span>
            </div>
          </div>

          <div class="cf__systems">
            <span class="cf__tech-label">Bekijk het resultaat</span>
            <div class="cf__sys-list">
              <a href="https://www.voetbalfunnoord.nl/" target="_blank" rel="noopener" class="btn btn--primary" style="margin-top:.5rem">Voetbalfunnoord.nl →</a>
            </div>
          </div>

        </div>

        <div class="cf__visual fade-in fade-in-delay-1">
          <div class="dashboard-mock">
            <div class="dm__chrome">
              <div class="dm__dots">
                <span class="dm__dot" style="background:#ff5f57"></span>
                <span class="dm__dot" style="background:#febc2e"></span>
                <span class="dm__dot" style="background:#28c840"></span>
              </div>
              <span class="dm__title">voetbalfunnoord.nl</span>
              <div class="dm__chrome-right">
                <span class="dm__ai-pill">
                  <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="5" r="3"/><path d="M2 11c0-2.2 1.8-4 4-4s4 1.8 4 4"/></svg>
                  Live
                </span>
              </div>
            </div>
            <div class="dm__body" style="padding:0">
              <img
                src="/assets/images/voetbalfunnoord-website.png"
                alt="Screenshot Voetbal Fun Noord website"
                style="width:100%;display:block;border-radius:0 0 10px 10px;object-fit:cover"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="cf__results fade-in">
        <div class="cf__result-card">
          <strong>Top 3</strong>
          <span>lokale Google-resultaten in de regio</span>
        </div>
        <div class="cf__result-card cf__result-card--orange">
          <strong>100%</strong>
          <span>mobielvriendelijke website met perfecte score</span>
        </div>
        <div class="cf__result-card">
          <strong>+240%</strong>
          <span>meer organisch websiteverkeer na livegang</span>
        </div>
        <div class="cf__result-card cf__result-card--orange">
          <strong>Nieuw</strong>
          <span>merkidentiteit die past bij de organisatie en haar doelgroep</span>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container cta-banner__inner">
      <div>
        <h2>Wil jij het volgende succesverhaal worden?</h2>
        <p>Plan een gratis gesprek en ontdek wat er mogelijk is voor jouw bedrijf.</p>
      </div>
      <a href="/#contact" class="btn btn--primary">Start een project →</a>
    </div>
  </section>

</BaseLayout>
