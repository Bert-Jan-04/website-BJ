---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/cases.json';
---

<BaseLayout title="Cases | SportSEO Specialist" pageCss="/assets/css/cases.css" current="cases">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="hero__bg">
      <div class="hero__circle hero__circle--1"></div>
      <div class="hero__circle hero__circle--2"></div>
      <div class="hero__grid"></div>
    </div>
    <div class="container page-hero__inner">
      <span class="section__label">{data.hero.label}</span>
      <h1>{data.hero.titlePlain}<span class="gradient-text">{data.hero.titleGradient}</span>{data.hero.titleSuffix}</h1>
      <p>{data.hero.subtitle}</p>
    </div>
  </section>

  {data.cases.map((c, i) => (
    <section class="section case-featured" id={c.id}>
      <div class="container">

        <div class="cf__header fade-in">
          <div class="cf__meta">
            <span class="cf__client">{c.client}</span>
            {c.badges.map((badge, bi) => (
              <span class={`cf__badge ${bi === 0 ? 'cf__badge--orange' : ''}`}>{badge}</span>
            ))}
          </div>
          <h2 class="cf__title">
            {c.titleLine1}<br />
            <span class="gradient-text">{c.titleGradient}</span>
          </h2>
          <p class="cf__lead">
            {c.lead}
          </p>
        </div>

        <div class="cf__detail">

          <div class="cf__content fade-in">

            <div class="cf__block">
              <div class="cf__block-label">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="10" cy="10" r="8"/><path d="M10 6v4l3 3"/></svg>
                De uitdaging
              </div>
              <p>
                {c.challenge}
              </p>
            </div>

            <div class="cf__block">
              <div class="cf__block-label cf__block-label--blue">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="14" cy="4" r="2"/><circle cx="6" cy="10" r="2"/><circle cx="14" cy="16" r="2"/><path d="M7.8 9l4.4-4M7.8 11l4.4 4"/></svg>
                De oplossing
              </div>
              <p>
                {c.solution}
              </p>
            </div>

            <div class="cf__tech">
              <span class="cf__tech-label">Wat er is gedaan</span>
              <div class="cf__tech-list">
                {c.tech.map((t) => (
                  <span class={`tool-badge ${t.highlighted ? 'tool-badge--orange' : ''}`}>{t.label}</span>
                ))}
              </div>
            </div>

            <div class="cf__systems">
              <span class="cf__tech-label">Bekijk het resultaat</span>
              <div class="cf__sys-list">
                <a href={c.resultLink} target="_blank" rel="noopener" class="btn btn--primary" style="margin-top:.5rem">{c.resultLabel}</a>
              </div>
            </div>

          </div>

          <div class="cf__visual fade-in fade-in-delay-1">
            <div class="dashboard-mock">
              <div class="dm__chrome">
                <div class="dm__dots">
                  <span class="dm__dot" style="background:#ff5f57"></span>
                  <span class="dm__dot" style="background:#febc2e"></span>
                  <span class="dm__dot" style="background:#28c840"></span>
                </div>
                <span class="dm__title">{c.browserTitle}</span>
                <div class="dm__chrome-right">
                  <span class="dm__ai-pill">
                    <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="5" r="3"/><path d="M2 11c0-2.2 1.8-4 4-4s4 1.8 4 4"/></svg>
                    Live
                  </span>
                </div>
              </div>
              <div class="dm__body" style="padding:0">
                <img
                  src={c.image}
                  alt={c.imageAlt}
                  style="width:100%;display:block;border-radius:0 0 10px 10px;object-fit:cover"
                />
              </div>
            </div>
          </div>
        </div>

        <div class="cf__results fade-in">
          {c.results.map((r) => (
            <div class={`cf__result-card ${r.highlighted ? 'cf__result-card--orange' : ''}`}>
              <strong>{r.value}</strong>
              <span>{r.label}</span>
            </div>
          ))}
        </div>

      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container cta-banner__inner">
      <div>
        <h2>{data.cta.title}</h2>
        <p>{data.cta.subtitle}</p>
      </div>
      <a href="/#contact" class="btn btn--primary">{data.cta.buttonLabel}</a>
    </div>
  </section>

</BaseLayout>
