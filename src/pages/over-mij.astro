---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/over-mij.json';

const passieIcons: Record<string, string> = {
  sport: '<circle cx="16" cy="16" r="12"/><path d="M16 4c0 0-4 5-4 12s4 12 4 12M16 4c0 0 4 5 4 12s-4 12-4 12"/><path d="M4.5 11h23M4.5 21h23"/>',
  marketing: '<path d="M27 5L15 15M27 5L19 27l-4-10L5 13l22-8z"/>',
  proces: '<circle cx="24" cy="6" r="3.5"/><circle cx="8" cy="16" r="3.5"/><circle cx="24" cy="26" r="3.5"/><path d="M11.2 14.7L20.8 8M11.2 17.3L20.8 24"/>',
};

const valueIcons = [
  '<polyline points="6 9 12 3 18 9"/><path d="M6 9H4a1 1 0 0 0-1 1v1a5 5 0 0 0 5 5h8a5 5 0 0 0 5-5v-1a1 1 0 0 0-1-1h-2"/><line x1="12" y1="16" x2="12" y2="21"/><line x1="8" y1="21" x2="16" y2="21"/>',
  '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
  '<path d="M17 11l-5-5-5 5"/><path d="M12 6v13"/><path d="M5 18c0 0 2-2 7-2s7 2 7 2"/>',
];
---

<BaseLayout title="Over mij | SportSEO Specialist" pageCss="/assets/css/over-mij.css" current="over-mij">
  <!-- HERO -->
  <section class="om-hero">
    <div class="hero__bg">
      <div class="hero__circle hero__circle--1"></div>
      <div class="hero__circle hero__circle--2"></div>
      <div class="hero__grid"></div>
    </div>
    <div class="container om-hero__inner">
      <div class="om-hero__text fade-in">
        <span class="section__label">Over mij</span>
        <h1>{data.hero.titleLine1}<br />{data.hero.titleLine2} <span class="gradient-text">{data.hero.titleGradient}</span></h1>
        <p class="om-hero__sub">
          {data.hero.subtitle}
        </p>
        <div class="om-hero__tags">
          {data.hero.tags.map((tag, i) => (
            <span class={i % 2 === 1 ? 'tag tag--orange' : 'tag'}>{tag}</span>
          ))}
        </div>
      </div>
      <div class="om-hero__photo fade-in fade-in-delay-1">
        <div class="om-photo-wrap">
          <img
            src={data.hero.photo}
            alt="Bert-Jan Russchen, SportSEO Specialist"
            class="om-photo"
          />
          <div class="om-photo-accent"></div>
        </div>
        <div class="om-hero__stat-bubble om-hero__stat-bubble--2">
          <strong>{data.hero.statBubble.value}</strong>
          <span>{data.hero.statBubble.label}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- MIJN VERHAAL -->
  <section class="section verhaal" id="verhaal">
    <div class="container verhaal__inner">
      <div class="verhaal__media fade-in">
        <div class="verhaal__photo-main">
          <img src={data.verhaal.photoMain} alt="Bert-Jan aan het hardlopen" />
        </div>
        <div class="verhaal__photo-small">
          <img src={data.verhaal.photoSmall} alt="Bert-Jan aan de bal" />
        </div>

        <div class="verhaal__exp-badge">
          <strong>{data.verhaal.badge.value}</strong>
          <span>{data.verhaal.badge.labelLine1}<br />{data.verhaal.badge.labelLine2}</span>
        </div>
      </div>
      <div class="verhaal__content fade-in fade-in-delay-1">
        <span class="section__label">Mijn verhaal</span>
        <h2>{data.verhaal.titleLine1}<br /><span class="gradient-text">{data.verhaal.titleGradient}</span></h2>
        {data.verhaal.paragraphs.map((p) => <p>{p}</p>)}
        <div class="over__values">
          {data.verhaal.values.map((value, i) => (
            <div class={`value fade-in fade-in-delay-${i + 1}`}>
              <div class="value__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={valueIcons[i]} /></div>
              <div>
                <strong>{value.title}</strong>
                <span>{value.text}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- DRIE PASSIES -->
  <section class="section passies" id="passies">
    <div class="container">
      <div class="section__header">
        <span class="section__label">{data.passies.label}</span>
        <h2>{data.passies.titleLine1} <span class="gradient-text">{data.passies.titleGradient}</span></h2>
        <p class="passies__sub">
          {data.passies.subtitle}
        </p>
      </div>
      <div class="passies__grid">
        {data.passies.cards.map((card, i) => (
          <div class={`passie-card ${i === 1 ? 'passie-card--featured' : ''} fade-in ${i > 0 ? `fade-in-delay-${i}` : ''}`}>
            <div class={`passie-card__header passie-card__header--${card.id}`}>
              <img src={card.image} alt={card.title} class="passie-card__img" />
              <div class="passie-card__icon">
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" set:html={passieIcons[card.id]} />
              </div>
            </div>
            <div class="passie-card__body">
              <h3>{card.title}</h3>
              <p>{card.text}</p>
              <div class="passie-card__items">
                {card.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WAAROM IK -->
  <section class="section aanpak" id="aanpak">
    <div class="container aanpak__inner">
      <div class="aanpak__content fade-in">
        <span class="section__label">Mijn aanpak</span>
        <h2>{data.aanpak.titleLine1}<br /><span class="gradient-text">{data.aanpak.titleGradient}</span></h2>
        <p>
          {data.aanpak.text}
        </p>
        <ul class="aanpak__lijst">
          {data.aanpak.items.map((item, i) => (
            <li class={`fade-in fade-in-delay-${Math.min(i + 1, 3)}`}>
              <div class="aanpak__check">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="4 10 8 14 16 6"/>
                </svg>
              </div>
              <div>
                <strong>{item.title}</strong>
                <span>{item.text}</span>
              </div>
            </li>
          ))}
        </ul>
        <a href="/#contact" class="btn btn--primary">{data.aanpak.buttonLabel}</a>
      </div>

      <div class="aanpak__rechts fade-in fade-in-delay-2">
        <div class="feiten-grid">
          {data.aanpak.stats.map((stat, i) => (
            <div class={`feit-card ${i === 1 || i === 2 ? 'feit-card--orange' : ''}`}>
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </div>
          ))}
        </div>
        <blockquote class="aanpak__quote">
          <svg class="quote-icon" viewBox="0 0 40 32" aria-hidden="true">
            <path d="M0 32V20C0 9 6 3 18 0l2 4C12 6 9 10 8 16h8v16H0zm22 0V20C22 9 28 3 40 0l2 4C34 6 31 10 30 16h8v16H22z" fill="currentColor"/>
          </svg>
          <p>{data.aanpak.quote}</p>
          <cite>{data.aanpak.quoteAuthor}</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container cta-banner__inner">
      <div>
        <h2>{data.cta.title}</h2>
        <p>{data.cta.subtitle}</p>
      </div>
      <a href="/#contact" class="btn btn--primary">{data.cta.buttonLabel}</a>
    </div>
  </section>

</BaseLayout>
