---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/diensten.json';

const icons: Record<string, string> = {
  'web-design': '<rect x="3" y="4" width="26" height="20" rx="3"/><path d="M3 11h26M10 28h12M16 24v4"/><circle cx="8" cy="7.5" r="1" fill="currentColor" stroke="none"/><circle cx="11.5" cy="7.5" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="7.5" r="1" fill="currentColor" stroke="none"/>',
  'social-media': '<rect x="2" y="2" width="28" height="28" rx="7"/><circle cx="16" cy="16" r="6"/><circle cx="23" cy="9" r="1.5" fill="currentColor" stroke="none"/>',
  'seo': '<circle cx="13" cy="13" r="8"/><path d="M19 19l8 8"/><path d="M10 13h6M13 10v6"/>',
  'marketing': '<path d="M26 4L14 14M26 4l-8 22-4-10-10-4 22-8z"/>',
  'automatisering': '<circle cx="24" cy="6" r="4"/><circle cx="8" cy="16" r="4"/><circle cx="24" cy="26" r="4"/><path d="M11.5 14.5l9-7M11.5 17.5l9 7"/>',
  'integraties': '<ellipse cx="16" cy="7" rx="12" ry="4"/><path d="M4 7v6c0 2.2 5.4 4 12 4s12-1.8 12-4V7"/><path d="M4 13v6c0 2.2 5.4 4 12 4s12-1.8 12-4v-6"/><path d="M4 19v6c0 2.2 5.4 4 12 4s12-1.8 12-4v-6"/>',
};

const stepIcons = [
  '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>',
  '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  '<polyline points="20 6 9 17 4 12"/>',
];

const pillIcons: Record<string, string> = {
  'web-design': '<rect x="2" y="3" width="16" height="13" rx="2"/><path d="M2 8h16"/>',
  'social-media': '<rect x="2" y="2" width="16" height="16" rx="4"/><circle cx="10" cy="10" r="3"/><circle cx="14.5" cy="5.5" r="0.8" fill="currentColor" stroke="none"/>',
  'seo': '<circle cx="8" cy="8" r="5"/><path d="M13 13l4 4"/>',
  'marketing': '<path d="M18 3L9 10M18 3l-6 16-3-7-7-3 16-6z"/>',
  'automatisering': '<circle cx="15" cy="4" r="2"/><circle cx="5" cy="10" r="2"/><circle cx="15" cy="16" r="2"/><path d="M7 10.8l6 4M13 5.2L7 9"/>',
};

const pillLabels: Record<string, string> = {
  'web-design': 'Web design',
  'social-media': 'Social media',
  'seo': 'SEO',
  'marketing': 'Marketing',
  'automatisering': 'Automatisering',
};
---

<BaseLayout title="Diensten | SportSEO Specialist" pageCss="/assets/css/diensten.css" current="diensten">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="hero__bg">
      <div class="hero__circle hero__circle--1"></div>
      <div class="hero__circle hero__circle--2"></div>
      <div class="hero__grid"></div>
    </div>
    <div class="container page-hero__inner">
      <span class="section__label">{data.hero.label}</span>
      <h1>{data.hero.titleLine1}<br /><span class="gradient-text">{data.hero.titleGradient}</span></h1>
      <p>{data.hero.subtitle}</p>
      <div class="page-hero__nav">
        {Object.entries(pillLabels).map(([id, label]) => {
          const d = data.diensten.find((s) => s.id === id)!;
          return (
            <a href={`#${id}`} class={`hero-pill ${d.variant === 'orange' ? 'hero-pill--orange' : ''}`}>
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" set:html={pillIcons[id]} />
              {label}
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════ TAK 1 ═══════════════ -->
  <div class="tak-banner">
    <div class="container tak-banner__inner">
      <div class="tak-banner__num">01</div>
      <div>
        <h2>{data.tak1.titlePlain}<span class="gradient-text">{data.tak1.titleGradient}</span></h2>
        <p>{data.tak1.description}</p>
      </div>
    </div>
  </div>

  {data.diensten.filter((d) => d.tak === 1).map((d, i) => (
    <section class={`service-section ${i % 2 === 1 ? 'service-section--alt' : ''}`} id={d.id}>
      <div class="container">
        <div class={`service-detail ${i % 2 === 1 ? 'service-detail--reverse' : ''}`}>
          <div class="service-detail__left">
            <div class={`service-detail__icon ${d.variant}`}>
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" set:html={icons[d.id]} />
            </div>
            <h2>{d.title}</h2>
            <p class="service-detail__lead">{d.lead}</p>
            <div class="service-detail__ideal">
              <span class="ideal__label">{d.idealLabel ?? 'Ideaal voor'}</span>
              <div class="ideal__tags">
                {d.ideal.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
            {d.stats && (
              <div class="seo-stats">
                {d.stats.map((stat) => (
                  <div class="seo-stat">
                    <strong>{stat.value}</strong>
                    <span>{stat.label}</span>
                  </div>
                ))}
              </div>
            )}
            <div class="service-detail__tools">
              <span class="tools__label">{d.id === 'social-media' ? 'Platforms' : d.id === 'marketing' ? 'Kanalen' : 'Tools & technologie'}</span>
              <div class="tools__list">
                {d.tools.map((tool) => (
                  <span class={`tool-badge ${tool.highlighted ? 'tool-badge--orange' : ''}`}>{tool.label}</span>
                ))}
              </div>
            </div>
            {d.id === 'social-media' && (
              <div class="format-showcase">
                <div class="format-item"><div class="format-preview format-preview--square">1:1</div><span>Post</span></div>
                <div class="format-item"><div class="format-preview format-preview--story">9:16</div><span>Story / Reel</span></div>
                <div class="format-item"><div class="format-preview format-preview--banner">16:9</div><span>Banner</span></div>
                <div class="format-item"><div class="format-preview format-preview--portrait">4:5</div><span>Portrait</span></div>
              </div>
            )}
          </div>
          <div class="service-detail__right">
            <div class="service-detail__card">
              <div class="sdc__header">
                <span class={`sdc__category ${d.variant === 'orange' ? 'sdc__category--orange' : ''}`}>{d.category}</span>
                <a href="/#contact" class="sdc__price sdc__price--cta">Offerte aanvragen →</a>
              </div>
              <ul class="sdc__includes">
                {d.includes.map((item) => <li>{item}</li>)}
              </ul>
              <a href="/#contact" class="btn btn--primary btn--full">Offerte aanvragen →</a>
              {d.note && <p class="sdc__note">{d.note}</p>}
            </div>
            {d.extras.length > 0 && (
              <div class="service-detail__extra-cards">
                {d.extras.map((extra) => (
                  <div class="extra-card">
                    <strong>{extra.label}</strong>
                    <span>{extra.note}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- ═══════════════ TAK 2 ═══════════════ -->
  <div class="tak-banner tak-banner--orange">
    <div class="container tak-banner__inner">
      <div class="tak-banner__num tak-banner__num--orange">02</div>
      <div>
        <h2>{data.tak2.titlePlain}<span class="gradient-text">{data.tak2.titleGradient}</span></h2>
        <p>{data.tak2.description}</p>
      </div>
    </div>
  </div>

  {data.diensten.filter((d) => d.tak === 2).map((d, i) => (
    <section class={`service-section ${i % 2 === 1 ? 'service-section--alt' : ''}`} id={d.id}>
      <div class="container">
        <div class={`service-detail ${i % 2 === 1 ? 'service-detail--reverse' : ''}`}>
          <div class="service-detail__left">
            <div class={`service-detail__icon ${d.variant}`}>
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" set:html={icons[d.id]} />
            </div>
            <h2>{d.title}</h2>
            <p class="service-detail__lead">{d.lead}</p>
            <div class="service-detail__ideal">
              <span class="ideal__label">{d.idealLabel ?? 'Ideaal voor'}</span>
              <div class="ideal__tags">
                {d.ideal.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
            <div class="service-detail__tools">
              <span class="tools__label">Tools</span>
              <div class="tools__list">
                {d.tools.map((tool) => (
                  <span class={`tool-badge ${tool.highlighted ? 'tool-badge--orange' : ''}`}>{tool.label}</span>
                ))}
              </div>
            </div>
          </div>
          <div class="service-detail__right">
            <div class="service-detail__card service-detail__card--orange">
              <div class="sdc__header">
                <span class="sdc__category sdc__category--orange">{d.category}</span>
                <a href="/#contact" class="sdc__price sdc__price--cta">Offerte aanvragen →</a>
              </div>
              <ul class="sdc__includes">
                {d.includes.map((item) => <li>{item}</li>)}
              </ul>
              <a href="/#contact" class="btn btn--primary btn--full">Offerte aanvragen →</a>
              {d.note && <p class="sdc__note">{d.note}</p>}
            </div>
            {d.extras.length > 0 && (
              <div class="service-detail__extra-cards">
                {d.extras.map((extra) => (
                  <div class="extra-card">
                    <strong>{extra.label}</strong>
                    <span>{extra.note}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- WERKWIJZE -->
  <section class="section werkwijze" id="werkwijze">
    <div class="container">
      <div class="section__header">
        <span class="section__label">{data.werkwijze.label}</span>
        <h2>{data.werkwijze.titleLine1} <span class="gradient-text">{data.werkwijze.titleGradient}</span></h2>
        <p class="werkwijze__sub">{data.werkwijze.subtitle}</p>
      </div>

      <div class="stappen-track">
        <div class="stappen-line"><div class="stappen-line__fill" id="stepLine"></div></div>

        {data.werkwijze.steps.map((step, i) => {
          const isFinish = i === data.werkwijze.steps.length - 1;
          const isRight = i % 2 === 1;
          return (
            <div class={`stap-item ${isRight ? 'stap-item--right' : ''} fade-in ${i > 0 ? `fade-in-delay-${i}` : ''}`}>
              <div class={`stap-item__dot ${isFinish ? 'stap-item__dot--finish' : ''}`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={isFinish ? '2.2' : '2'} set:html={stepIcons[i]} />
              </div>
              <div class={`stap-item__card ${isFinish ? 'stap-item__card--finish' : ''}`}>
                <div class={`stap-item__num ${isFinish ? 'stap-item__num--finish' : ''}`}>{step.num}</div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
                <ul class="stap-item__details">
                  {step.details.map((detail) => <li>{detail}</li>)}
                </ul>
                <div class={`stap-item__duration ${isFinish ? 'stap-item__duration--finish' : ''}`}>
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                    {isFinish ? <><polyline points="13 3 8 8 5 5"/><circle cx="8" cy="8" r="6"/></> : <><circle cx="8" cy="8" r="6"/><path d="M8 5v3l2 2"/></>}
                  </svg>
                  {step.duration}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner">
    <div class="container cta-banner__inner">
      <div>
        <h2>{data.cta.title}</h2>
        <p>{data.cta.subtitle}</p>
      </div>
      <a href="/#contact" class="btn btn--primary">{data.cta.buttonLabel}</a>
    </div>
  </section>

</BaseLayout>
